<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Ameko.App"
             RequestedThemeVariant="Dark">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Styles>
        <SimpleTheme />
		<StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Simple.xaml"/>
		<StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Simple/Simple.xaml" />
		<StyleInclude Source="avares://AvaloniaEdit/Themes/Simple/AvaloniaEdit.xaml" />
		<StyleInclude Source="avares://Ameko/Assets/Styles/SeekSlider.axaml" />
		
		<Style Selector="Svg">
			<Setter Property="(Svg.Css)" Value="path { fill: #FFFFFF; }" />
		</Style>
    </Application.Styles>
	<Application.Resources>
		<FontFamily x:Key="Migu2MRegular">avares://Ameko/Assets/Fonts/migu-2m-regular.ttf#Migu 2M</FontFamily>
		<FontFamily x:Key="MonoidRegular">avares://Ameko/Assets/Fonts/Monoid-Regular.ttf#Monoid</FontFamily>
	</Application.Resources>
</Application>
